#!/bin/bash

################################################################################
# FnRmux 公共函数库
# 包含安装、卸载、升级过程中使用的公共函数
################################################################################

# ============================================================================
# 工具快捷方式
# ============================================================================
MV="/bin/mv -f"
RM="/bin/rm -rf"
CP="/bin/cp -rfp"
MKDIR="/bin/mkdir -p"
LN="/bin/ln -nsf"

# ============================================================================
# 路径定义
# ============================================================================
INST_ETC="/var/apps/${TRIM_APPNAME}/etc"
INST_VARIABLES="${INST_ETC}/installer-variables"
INST_LOG="/var/log/apps/${TRIM_APPNAME}.log"

# PKGVAR 是 @appdata 目录
LOG_FILE="${TRIM_PKGVAR}/${TRIM_APPNAME}.log"
PID_FILE="${TRIM_PKGVAR}/${TRIM_APPNAME}.pid"

# ============================================================================
# 日志函数
# ============================================================================
install_log ()
{
    local _msg_="$@"
    if [ -z "${_msg_}" ]; then
        while IFS=$'\n' read -r line; do
            install_log "${line}"
        done
    else
        echo -e "$(date +'%Y/%m/%d %H:%M:%S')\t${_msg_}" 1>&2
    fi
}

log_step ()
{
    install_log "===> Step $1. STATUS=${TRIM_APP_STATUS} PKGVAR=${TRIM_PKGVAR}"
}

is_upgrade_flow ()
{
    case "$(printf '%s' "${TRIM_APP_STATUS}" | tr '[:lower:]' '[:upper:]')" in
        *UPGRADE*|*UPDATE*) return 0 ;;
        *) return 1 ;;
    esac
}

volume_root ()
{
    case "${TRIM_PKGVAR}" in
        /*/@appdata/*) printf '%s' "${TRIM_PKGVAR%%/@appdata/*}"; return 0 ;;
    esac
    case "${TRIM_APPDEST}" in
        /*/@appcenter/*) printf '%s' "${TRIM_APPDEST%%/@appcenter/*}"; return 0 ;;
    esac
    return 1
}

# ============================================================================
# 服务管理函数
# ============================================================================

stop_tmux_sessions ()
{
    install_log "停止所有 FnRmux 相关的终端进程..."
    
    # 清理所有 FnRmux 启动的 tmux 进程 (根据我们的专用 socket 路径识别)
    pkill -f "tmux.*-S /tmp/fnrmux_socks" 2>/dev/null || true
    
    # 清理全局临时文件
    rm -rf /tmp/fnrmux_socks 2>/dev/null
    rm -rf /tmp/fnrmux_clipboard 2>/dev/null
    rm -f /tmp/fnrmux_shell_wrapper.sh 2>/dev/null
    rm -f /tmp/fnrmux_hit.log /tmp/fnrmux_debug.log /tmp/fnrmux_xclip.log 2>/dev/null
    
    install_log "  服务进程与临时资源已清理"
}

stop_fnrmux_server ()
{
    install_log "停止 FnRmux 后端服务..."

    local pid=""
    if [ -f "${PID_FILE}" ]; then
        pid="$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')"
        if [ -n "${pid}" ] && kill -0 "${pid}" 2>/dev/null; then
            kill -TERM "${pid}" 2>/dev/null || true
            local count=0
            while kill -0 "${pid}" 2>/dev/null && [ "${count}" -lt 10 ]; do
                sleep 1
                count=$((count + 1))
            done
            if kill -0 "${pid}" 2>/dev/null; then
                kill -KILL "${pid}" 2>/dev/null || true
            fi
        fi
        rm -f "${PID_FILE}"
    fi

    # 升级时旧二进制可能仍在运行，但 pid 文件已缺失或不可信。
    pkill -TERM -f "${TRIM_APPDEST}/server/${TRIM_APPNAME}" 2>/dev/null || true
    sleep 1
    pkill -KILL -f "${TRIM_APPDEST}/server/${TRIM_APPNAME}" 2>/dev/null || true

    install_log "  后端服务已停止"
}

stop_runtime ()
{
    stop_fnrmux_server
    stop_tmux_sessions
}

# ============================================================================
# 清理函数
# ============================================================================

# 删除临时运行时文件 (通常用于升级)
clean_temp_files ()
{
    install_log "清理运行时临时文件..."
    
    rm -f "${TRIM_PKGVAR}/fnrmux.log"
    rm -f "${TRIM_PKGVAR}/fnrmux.pid"
    rm -f "${TRIM_PKGVAR}/fnrmux_jwt_secret_v2"
    rm -rf "${TRIM_PKGVAR}/sessions"
    rm -rf "${TRIM_PKGVAR}/logs"
    rm -rf "${TRIM_PKGVAR}/outputs"
    
    install_log "临时文件清理完成"
}

# 彻底删除所有用户数据 (用于卸载)
clean_all_data ()
{
    install_log "正在彻底删除所有用户数据..."

    # 先停服务，再删除安装目录，避免进程仍持有旧二进制或临时文件。
    stop_runtime
    
    # 1. 清理数据目录 (@appdata)
    if [ -d "${TRIM_PKGVAR}" ]; then
        install_log "  删除数据目录: ${TRIM_PKGVAR}"
        rm -rf "${TRIM_PKGVAR}"
    fi

    # 2. 清理共享目录，避免文件管理器继续显示“应用文件/fnrmux”
    local volume=""
    if volume="$(volume_root)" && [ -n "${TRIM_APPNAME}" ] && [ -d "${volume}/@appshare/${TRIM_APPNAME}" ]; then
        install_log "  删除共享目录: ${volume}/@appshare/${TRIM_APPNAME}"
        rm -rf "${volume}/@appshare/${TRIM_APPNAME}"
    fi

    # 3. 清理系统配置及二进制目录
    if [ -n "${TRIM_APPNAME}" ]; then
        if [ -d "/var/apps/${TRIM_APPNAME}" ]; then
            install_log "  清理系统配置: /var/apps/${TRIM_APPNAME}"
            rm -rf "/var/apps/${TRIM_APPNAME}"
        fi
        if [ -n "${TRIM_APPDEST}" ] && [ -d "${TRIM_APPDEST}" ]; then
            install_log "  清理中心目录: ${TRIM_APPDEST}"
            rm -rf "${TRIM_APPDEST}"
        fi
        if [ -e "/var/apps_ui/${TRIM_APPNAME}" ]; then
            install_log "  清理桌面 UI 链接: /var/apps_ui/${TRIM_APPNAME}"
            rm -rf "/var/apps_ui/${TRIM_APPNAME}"
        fi
        if [ -e "/usr/local/apps/@appcenter/${TRIM_APPNAME}" ]; then
            install_log "  清理本地中心链接: /usr/local/apps/@appcenter/${TRIM_APPNAME}"
            rm -rf "/usr/local/apps/@appcenter/${TRIM_APPNAME}"
        fi
    fi

    # 4. 清理公共临时资源
    rm -rf /tmp/fnrmux*
    
    install_log "所有数据已彻底清除，卸载完成"
}

# ============================================================================
# 安装钩子函数
# ============================================================================

install_init ()
{
    log_step "install_init"
    if ! is_upgrade_flow; then
        rm -f "${TRIM_PKGVAR}/.upgrading"
    fi
    exit 0
}

install_callback ()
{
    log_step "install_callback"
    if ! is_upgrade_flow; then
        rm -f "${TRIM_PKGVAR}/.upgrading"
    fi
    
    # 创建必要的子目录
    $MKDIR "${TRIM_PKGVAR}/sessions"
    $MKDIR "${TRIM_PKGVAR}/logs"
    $MKDIR "${TRIM_PKGVAR}/outputs"
    $MKDIR "${TRIM_PKGVAR}/backgrounds"
    
    # 确保权限
    chmod 777 "${TRIM_PKGVAR}/outputs"
    chmod 777 "${TRIM_PKGVAR}/backgrounds"
    
    install_log "安装完成，环境已就绪"
    exit 0
}

# ============================================================================
# 卸载钩子函数
# ============================================================================

uninstall_init ()
{
    log_step "uninstall_init"
    stop_runtime
    exit 0
}

uninstall_callback ()
{
    log_step "uninstall_callback"

    # 只有真实升级流程才跳过数据删除；普通卸载遇到旧标记也必须清理。
    if is_upgrade_flow; then
        install_log "检测到升级流程，跳过数据清理"
        exit 0
    fi

    UPGRADE_FLAG="${TRIM_PKGVAR}/.upgrading"
    if [ -f "${UPGRADE_FLAG}" ]; then
        install_log "发现残留升级标记，按普通卸载处理并删除: ${UPGRADE_FLAG}"
        rm -f "${UPGRADE_FLAG}"
    fi
    
    # 完全卸载：fnOS 默认会询问是否删除数据
    # 这里我们执行最彻底的清理
    install_log "执行彻底卸载流程..."
    clean_all_data
    
    exit 0
}

# ============================================================================
# 升级钩子函数
# ============================================================================

upgrade_init ()
{
    log_step "upgrade_init"
    # 创建升级标记，防止卸载回调误删数据
    $MKDIR "${TRIM_PKGVAR}"
    date +%s > "${TRIM_PKGVAR}/.upgrading"
    stop_runtime
    exit 0
}

upgrade_callback ()
{
    log_step "upgrade_callback"
    rm -f "${TRIM_PKGVAR}/.upgrading"
    
    # 升级时仅清理旧的运行时临时文件
    clean_temp_files
    
    # 重建目录结构
    $MKDIR "${TRIM_PKGVAR}/sessions"
    $MKDIR "${TRIM_PKGVAR}/logs"
    $MKDIR "${TRIM_PKGVAR}/outputs"
    $MKDIR "${TRIM_PKGVAR}/backgrounds"
    
    install_log "升级完成，服务已重启"
    exit 0
}
