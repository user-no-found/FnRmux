#!/bin/bash
set -u

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
PKG_ROOT=$(CDPATH= cd -- "${SCRIPT_DIR}/.." && pwd)
APP_DEST="${TRIM_APPDEST:-${PKG_ROOT}}"
PKG_VAR="${TRIM_PKGVAR:-${PKG_ROOT}/var}"
LOG_FILE="${PKG_VAR}/fnrmux.log"
PID_FILE="${PKG_VAR}/fnrmux.pid"
PORT="${TRIM_SERVICE_PORT:-18732}"
APP_NAME="fnrmux"

log_msg() {
    mkdir -p "$(dirname "${LOG_FILE}")"
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> "${LOG_FILE}"
}

check_process() {
    local pid="$1"
    kill -0 "${pid}" 2>/dev/null
}

resolve_app_bin() {
    for path in \
        "${APP_DEST}/server/fnrmux" \
        "${PKG_ROOT}/server/fnrmux"
    do
        if [ -x "${path}" ]; then
            printf "%s" "${path}"
            return 0
        fi
    done
    return 1
}

status_process() {
    if [ -f "${PID_FILE}" ]; then
        local pid
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        if [ -n "${pid}" ] && check_process "${pid}"; then
            return 0
        fi
        rm -f "${PID_FILE}"
    fi
    return 3
}

stop_stale_processes() {
    mkdir -p "$(dirname "${LOG_FILE}")"

    local pid=""
    if [ -f "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        if [ -n "${pid}" ] && check_process "${pid}"; then
            kill -TERM "${pid}" >> "${LOG_FILE}" 2>&1 || true
        fi
        rm -f "${PID_FILE}"
    fi

    pkill -TERM -f "${APP_DEST}/server/${APP_NAME}" >> "${LOG_FILE}" 2>&1 || true

    local count=0
    while [ "${count}" -lt 5 ]; do
        sleep 1
        if ! pgrep -f "${APP_DEST}/server/${APP_NAME}" >/dev/null 2>&1; then
            return 0
        fi
        count=$((count + 1))
    done

    pkill -KILL -f "${APP_DEST}/server/${APP_NAME}" >> "${LOG_FILE}" 2>&1 || true
    sleep 1
}

start_process() {
    if status_process; then
        log_msg "FnRmux 已在运行。"
        return 0
    fi

    stop_stale_processes

    local app_bin
    if ! app_bin=$(resolve_app_bin); then
        log_msg "未找到可执行文件"
        return 1
    fi

    log_msg "启动 FnRmux：端口 ${PORT}"

    # 设置 tmux 运行环境
    export PATH="${APP_DEST}/server/bin:${PATH}"
    export LD_LIBRARY_PATH="${APP_DEST}/server/lib:${LD_LIBRARY_PATH:-}"

    HOST=0.0.0.0 PORT="${PORT}" TRIM_PKGVAR="${PKG_VAR}" TRIM_APPDEST="${APP_DEST}" \
    nohup "${app_bin}" >> "${LOG_FILE}" 2>&1 &
    printf "%s" "$!" > "${PID_FILE}"

    # 等待端口就绪
    local i
    for i in {1..15}; do
        sleep 0.3
        if status_process; then
            log_msg "FnRmux 已启动 (PID: $(cat "${PID_FILE}"))"
            return 0
        fi
    done

    log_msg "启动失败"
    return 1
}

stop_process() {
    log_msg "停止 FnRmux。"
    stop_stale_processes
    log_msg "FnRmux 已停止"
    return 0
}

case "${1:-}" in
start) start_process ;;
stop)  stop_process ;;
status) status_process ;;
restart) stop_process; sleep 1; start_process ;;
*) exit 1 ;;
esac
